<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 - Lost in the Blogverse</title>
    <link rel="stylesheet" href="/assets/css/common.min.css">
    <link rel="stylesheet" href="/assets/css/errors.min.css">
</head>
<body class="app-page error-page">
<main class="app-container error-container">
    <p class="error-code">404</p>
    <h1 class="error-title">You found a page from another timeline.</h1>
    <p class="error-text">
        This URL drifted out of the blog universe. The good news: the rest of the site is still here.
    </p>

    <div class="error-actions">
        <a class="error-btn error-btn--primary" href="/">Return to Blog</a>
        <a class="error-btn" href="/">Start Over</a>
    </div>

    <div class="error-orbit" aria-hidden="true">
        <span class="error-orbit__planet"></span>
        <span class="error-orbit__satellite"></span>
    </div>
</main>
</body>
</html>
